# -----------------------------------------------------------------------------
# Python IBKR Connector Environment (v1 Skeleton)
# Tiny connector boundary; mode and safety checks are env-driven.
# -----------------------------------------------------------------------------

# Allowed values: paper | live
TRADING_MODE=paper

# Must be true to permit live mode. If TRADING_MODE=live and this is not true,
# connector must fail fast.
LIVE_TRADING_ENABLED=false

# -----------------------------------------------------------------------------
# IBKR Endpoint Settings by Mode
# -----------------------------------------------------------------------------
# Paper (TWS / IB Gateway paper endpoint)
IBKR_PAPER_HOST=127.0.0.1
IBKR_PAPER_PORT=7497
IBKR_PAPER_CLIENT_ID=1

# Live (TWS / IB Gateway live endpoint)
IBKR_LIVE_HOST=127.0.0.1
IBKR_LIVE_PORT=7496
IBKR_LIVE_CLIENT_ID=2

# -----------------------------------------------------------------------------
# Connector Runtime Options
# -----------------------------------------------------------------------------
IBKR_CONNECT_TIMEOUT_SECONDS=10
LOG_LEVEL=INFO
