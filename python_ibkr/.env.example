# -----------------------------------------------------------------------------
# Python IBKR Connector Environment (T03)
# -----------------------------------------------------------------------------

# Preferred mode variable for connector scripts: paper | live
IBKR_MODE=paper

# Backward-compatible alias from T01 contract. If IBKR_MODE is unset, TRADING_MODE
# is used as a fallback.
TRADING_MODE=paper

# Must be true to permit live mode.
LIVE_TRADING_ENABLED=false

# Paper endpoint
IBKR_PAPER_HOST=127.0.0.1
IBKR_PAPER_PORT=7497
IBKR_PAPER_CLIENT_ID=1

# Live endpoint
IBKR_LIVE_HOST=127.0.0.1
IBKR_LIVE_PORT=7496
IBKR_LIVE_CLIENT_ID=2

# Runtime
IBKR_CONNECT_TIMEOUT_SECONDS=10
