# -----------------------------------------------------------------------------
# Laravel Application Environment (v1 Skeleton)
# Self-use local swing assistant; paper-first safety defaults.
# -----------------------------------------------------------------------------

APP_NAME="LeanSwingAssistant"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Database (MySQL)
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lean_swing_assistant
DB_USERNAME=root
DB_PASSWORD=

# -----------------------------------------------------------------------------
# OpenAI (used by Laravel for prompt-based ranking/interpretation)
# No hardcoded secrets. Fill locally in .env.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# Trading Safety Controls (canonical)
# -----------------------------------------------------------------------------
# Allowed values: paper | live
TRADING_MODE=paper

# Must be true to permit live mode. If TRADING_MODE=live and this is not true,
# application must fail fast.
LIVE_TRADING_ENABLED=false

# ----------------------------------------------------------------------------
# T11 Paper Trade Execution
# ----------------------------------------------------------------------------
BROKER_TRADING_MODE=paper
EXECUTION_ENABLED=false
EXECUTION_DEFAULT_QUANTITY=1
EXECUTION_PYTHON_EXECUTABLE=python
